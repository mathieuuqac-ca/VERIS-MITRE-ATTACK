{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install requirements",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "Semaine 2 - Ingestion VCDB",
      "type": "shell",
      "command": "python -m e3_pipeline.ingest_vcdb --limit 20",
      "options": {
        "env": {
          "PYTHONPATH": "${workspaceFolder}/src"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Semaine 4 - Wrapper mock",
      "type": "shell",
      "command": "python -m e3_pipeline.llm_wrapper --mock --limit 5",
      "options": {
        "env": {
          "PYTHONPATH": "${workspaceFolder}/src"
        }
      },
      "problemMatcher": []
    }
  ]
}
